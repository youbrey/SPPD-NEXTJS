# .env.local — Template Variabel Lingkungan SIPS Web
# JANGAN commit file ini ke Git! Sudah ada di .gitignore

# ─── DATABASE (Neon Serverless PostgreSQL) ─────────────────────────────────
# Daftar gratis di: https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/sips_db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/sips_db?sslmode=require"

# ─── AUTH (NextAuth.js v5) ───────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-random-string-64-karakter-yang-aman"
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_URL="https://sips.dprd-bitung.go.id"  # Production

# ─── REDIS (Upstash — untuk cache & rate limiting) ──────────────────────────
# Daftar gratis di: https://upstash.com
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── FILE STORAGE (Vercel Blob) ──────────────────────────────────────────────
# Di-generate otomatis oleh Vercel saat enable Blob storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# ─── APP CONFIG ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="SIPS"
NEXT_PUBLIC_APP_VERSION="7.0"
NEXT_PUBLIC_INSTANSI="DPRD Kota Bitung"
NEXT_PUBLIC_INSTANSI_ALAMAT="Jl. Sam Ratulangi No. 1, Kota Bitung, Sulawesi Utara"

# ─── ENVIRONMENT ─────────────────────────────────────────────────────────────
NODE_ENV="development"
# NODE_ENV="production"

# ─────────────────────────────────────────────────────────────────────────────
# PANDUAN SETUP CEPAT (StackBlitz / Lokal / Vercel)
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. SETUP LOKAL:
#    npm install
#    cp .env.example .env.local
#    # Isi DATABASE_URL dengan koneksi PostgreSQL lokal atau Neon
#    npx prisma db push     # Buat tabel dari schema
#    npx prisma db seed     # Isi data awal (personel default)
#    npm run dev            # Jalankan di http://localhost:3000
#
# 2. SETUP STACKBLITZ:
#    - Buka https://stackblitz.com, New Project → Next.js
#    - Copy semua file ke project
#    - Di panel "Secrets" (ikon kunci), tambahkan:
#        DATABASE_URL → koneksi Neon
#        AUTH_SECRET  → random string
#    - Klik Run
#
# 3. DEPLOY KE VERCEL:
#    npm install -g vercel
#    vercel login
#    vercel                           # Deploy pertama kali
#    vercel env add DATABASE_URL      # Tambah env vars
#    vercel env add AUTH_SECRET
#    vercel --prod                    # Deploy production
#
# 4. DATABASE MIGRATION (setelah schema berubah):
#    npx prisma migrate dev --name "nama_perubahan"
#    npx prisma generate
#
# 5. IMPORT PERSONEL:
#    - Login ke aplikasi → menu "Data Personel"
#    - Klik "Import dari Excel"
#    - Upload file database_dprd_asn.xlsx (format sama dengan versi Python)
#    - Sistem auto-detect sheet DPRD & ASN
